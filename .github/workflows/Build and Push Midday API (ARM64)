name: Build and Push Midday API (ARM64)

on:
  push:
    branches:
      - main
    # Only trigger when relevant backend files change
    paths:
      - 'apps/api/**'
      - 'packages/**'
      - 'package.json'
      - 'pnpm-lock.yaml'
  workflow_dispatch: # Allows you to trigger the build manually from the GitHub UI

env:
  REGISTRY: ghcr.io
  # Converts your username to lowercase automatically (GHCR requirement)
  IMAGE_NAME: ${{ github.repository_owner }}/midday-api

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write # Required to push to GHCR

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      # 1. Setup QEMU (Required to build ARM64 on Ubuntu runners)
      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3

      # 2. Setup Buildx (The Docker engine extension that handles multi-arch)
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      # 3. Authenticate with GHCR
      - name: Log in to GitHub Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }} # This is injected automatically by GitHub

      # 4. Bypass the Railway CI dependency
      - name: Create git-commit-sha file
        run: echo "${{ github.sha }}" > .git-commit-sha

      # 5. Extract tags (creates 'latest' and a unique SHA tag for ArgoCD rollbacks)
      - name: Extract Docker metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}
          tags: |
            type=raw,value=latest
            type=sha,format=short

      # 6. Build and Push the ARM64 Image
      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: apps/api/Dockerfile
          platforms: linux/arm64
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
